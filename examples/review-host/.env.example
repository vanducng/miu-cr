# Copy to .env for docker compose. Keep .env untracked.

MIUCR_HOST_CONFIG=./config.local.yaml
MIUCR_PG_DSN=postgres://miucr:miucr@postgres:5432/miucr?sslmode=disable
MIUCR_LOG_LEVEL=debug
MIUCR_TRACE_LOG=false
MIUCR_TRACE_LOG_MAX_BYTES=4096

# LLM provider credential used by providers.anthropic.auth_env.
ANTHROPIC_API_KEY=

# PAT examples used by github.accounts.*.auth_env.
GITHUB_TOKEN=
GITHUB_COMPANY_TOKEN=

# App example used by github.accounts.company-app.
MIUCR_EXAMPLE_GITHUB_APP_ID=
MIUCR_EXAMPLE_GITHUB_APP_INSTALLATION_ID=
MIUCR_EXAMPLE_GITHUB_APP_PRIVATE_KEY_PATH=/run/secrets/github-app-private-key.pem
